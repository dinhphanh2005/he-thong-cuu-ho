        {
          "name": "5. Set Availability AVAILABLE (Rescue)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": "{{base_url}}/rescue-teams/availability"
          }
        },
        {
          "name": "6. Phân Công Thủ Công (Dispatcher)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "console.log('✅ Assigned:', res.message);"
          ]}}],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/rescue-teams/{{team_id}}/assign/{{incident_id}}"
          }
        }
      ]
    },
    {
      "name": "📁 REPORTS (Dispatcher/Admin)",
      "item": [
        {
          "name": "1. Summary",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const d = pm.response.json().data;",
            "console.log('📊 Total:', d?.total, '| SOS:', d?.sosCount, '| Avg response:', d?.avgResponseTimeMinutes, 'phút');"
          ]}}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/summary",
              "query": [
                { "key": "from", "value": "2026-01-01", "disabled": true },
                { "key": "to", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "2. Heatmap",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const res = pm.response.json();",
            "console.log('🗺️ Heatmap points:', res.count);"
          ]}}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/heatmap",
              "query": [
                { "key": "type", "value": "ACCIDENT", "disabled": true },
                { "key": "severity", "value": "CRITICAL", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "3. Timeline",
          "request": {
