# Cấu hình Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database_name

# Cấu hình Server
PORT=5001
NODE_ENV=development

# Cấu hình JWT
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=24h

# Cấu hình CORS (Các domain được phép truy cập)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cấu hình Redis (Nếu dùng Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cấu hình Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cấu hình Firebase (Nếu dùng Push Notification)
# FIREBASE_PROJECT_ID=...
